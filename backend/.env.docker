APP_NAME=BI Platform API
APP_ENV=development
APP_DEBUG=true
API_V1_PREFIX=/v1
DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/bi
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ISSUER=bi-platform-api
JWT_AUDIENCE=bi-platform-clients
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_MINUTES=10080
AUTH_STORAGE_MODE=sql
AUTH_SEED_DEMO_USERS=true
REDIS_URL=redis://redis:6379/0
