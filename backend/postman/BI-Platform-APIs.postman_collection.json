      "name": "Internal Pipeline",
      "item": [
        {
          "name": "KPI Orchestrator Ingest Completed",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                  "const json = pm.response.json();",
                  "if (json.periods && json.periods.length > 0) {",
                  "  const first = json.periods[0];",
                  "  if (first.orchestrator_run_id) { pm.environment.set('orchestratorRunId', first.orchestrator_run_id); }",
                  "  if (first.period_ref) { pm.environment.set('periodRef', first.period_ref); }",
                  "}"
